{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="bg-background py-12 md:py-24 px-margin-mobile md:px-margin-desktop">
  <div class="max-w-container-max mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20">
    <!-- Product Gallery -->
    <div class="space-y-6">
      <div class="aspect-square bg-white rounded-sm overflow-hidden flex items-center justify-center p-6 md:p-16 border border-surface-container">
        {%- if product.featured_image != blank -%}
          {{ product.featured_image | image_url: width: 1200 | image_tag: class: 'w-full h-full object-contain hover:scale-105 transition-transform duration-1000' }}
        {%- else -%}
          <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDkRQl8tsTi748apldWsA5bIG9McE3KLWcZIGZHsIxoIUINNlWK28b_lN4ju5n342SRcUkhAaHkjm3MuII31UcPF9WPAXudEXn8KhUJ9hzpvKd2-Xrp4X9pGnPapgVP3KeSlhe5QuQy356iIU8Eg8vXlOeimbMRl9xqKnI4ix5QzgCwjL7Eg6PksURkZ1yN42G6H_C5prZpEXf_o8uv0kg2o-f9msZvjZ8tTWYLzjLFfxoA-YPFWKpRKofQRNlVhP4RWV9vLoPnzA" class="w-full h-full object-contain" alt="Signature Gold">
        {%- endif -%}
      </div>
      
      {%- if product.images.size > 1 -%}
      <div class="grid grid-cols-4 gap-4">
        {%- for image in product.images limit: 4 -%}
          <div class="aspect-square bg-white rounded-sm overflow-hidden cursor-pointer border {% if forloop.first %}border-[#D4AF37]{% else %}border-surface-container{% endif %}">
            {{ image | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover hover:opacity-80 transition-opacity' }}
          </div>
        {%- endfor -%}
      </div>
      {%- endif -%}
    </div>

    <!-- Product Details -->
    <div class="flex flex-col justify-center" x-data="{ 
        selectedVariantId: {{ current_variant.id }},
        selectedVariantPrice: '{{ current_variant.price | money }}',
        quantity: 1,
        variants: [
          {%- for variant in product.variants -%}
            {
              id: {{ variant.id }},
              title: '{{ variant.title | escape }}',
              price: '{{ variant.price | money }}',
              available: {{ variant.available }},
              options: {{ variant.options | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
    }">
      {%- form 'product', product, class: 'product-form' -%}
        <input type="hidden" name="id" :value="selectedVariantId">
        
        <div class="mb-8">
          <span class="inline-block text-[#D4AF37] font-body text-label-md uppercase tracking-[0.3em] mb-4">SIGNATURE SERIES</span>
          <h1 class="font-display text-headline-xl text-primary mb-6 leading-tight">{{ product.title | default: 'Signature Gold' }}</h1>
          
          <div class="flex items-center gap-6 mb-8">
            <p class="font-display text-headline-md text-primary" x-text="selectedVariantPrice">{{ current_variant.price | money | default: '$245.00' }}</p>
            <div class="flex items-center text-[#D4AF37]">
              <div class="flex mr-2">
                  {% for i in (1..5) %}
                      <span class="material-symbols-outlined text-[18px]">star</span>
                  {% endfor %}
              </div>
              <span class="text-on-surface-variant font-body text-body-sm">(48 Reviews)</span>
            </div>
          </div>
          
          <div class="prose prose-sm font-body text-body-md text-on-surface-variant max-w-none mb-10">
            {{ product.description }}
          </div>
        </div>

        <!-- Variant Selectors -->
        {%- if product.has_only_default_variant == false -%}
          <div class="space-y-8 mb-12">
            {%- for option in product.options_with_values -%}
              <div>
                <label class="font-body text-label-md text-primary uppercase tracking-widest mb-4 block">{{ option.name }}</label>
                <div class="flex flex-wrap gap-4">
                  {%- for value in option.values -%}
                    <button 
                      type="button"
                      @click="
                        $dispatch('variant-change', { optionIndex: {{ forloop.parentloop.index0 }}, value: '{{ value }}' });
                        let newVariant = variants.find(v => v.options[{{ forloop.parentloop.index0 }}] === '{{ value }}');
                        if (newVariant) {
                          selectedVariantId = newVariant.id;
                          selectedVariantPrice = newVariant.price;
                        }
                      "
                      class="px-8 py-3 border rounded-sm font-body text-body-sm transition-all tracking-widest uppercase"
                      :class="variants.find(v => v.id === selectedVariantId).options[{{ forloop.parentloop.index0 }}] === '{{ value }}' ? 'border-[#D4AF37] bg-[#D4AF37]/5 text-[#D4AF37]' : 'border-outline-variant text-on-surface-variant hover:border-primary'"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Add to Cart -->
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <div class="flex items-center border border-outline-variant rounded-sm px-6 py-4 bg-white shadow-sm">
            <button type="button" @click="if(quantity > 1) quantity--" class="text-primary hover:text-[#D4AF37] p-1" aria-label="Decrease quantity"><span class="material-symbols-outlined text-[20px]">remove</span></button>
            <input type="number" name="quantity" x-model="quantity" class="w-16 text-center border-none focus:ring-0 font-body text-body-lg text-primary bg-transparent" aria-label="Quantity" min="1">
            <button type="button" @click="quantity++" class="text-primary hover:text-[#D4AF37] p-1" aria-label="Increase quantity"><span class="material-symbols-outlined text-[20px]">add</span></button>
          </div>
          <button type="submit" class="flex-1 bg-primary text-secondary-fixed font-body text-label-lg uppercase py-5 rounded-sm hover:bg-surface-container-highest transition-all flex items-center justify-center gap-3 tracking-[0.2em] group" :disabled="!variants.find(v => v.id === selectedVariantId).available">
            <span x-text="variants.find(v => v.id === selectedVariantId).available ? 'ADD TO BAG' : 'OUT OF STOCK'">ADD TO BAG</span>
            <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">shopping_bag</span>
          </button>
        </div>
      {%- endform -%}

      <!-- Accordions -->
      <div class="border-t border-outline-variant pt-4" x-data="{ open: 1 }">
        <div class="py-6 border-b border-outline-variant">
          <button @click="open = open === 1 ? 0 : 1" class="w-full flex items-center justify-between text-left">
            <span class="font-body text-label-lg text-primary uppercase tracking-widest">Scent Notes</span>
            <span class="material-symbols-outlined transition-transform duration-300" :class="open === 1 ? 'rotate-180' : ''">expand_more</span>
          </button>
          <div x-show="open === 1" x-collapse class="mt-6 font-body text-body-md text-on-surface-variant leading-relaxed">
            <p class="mb-2"><strong class="text-primary">Top:</strong> Saffron, Raspberry, Thyme</p>
            <p class="mb-2"><strong class="text-primary">Heart:</strong> Jasmine, Olibanum</p>
            <p><strong class="text-primary">Base:</strong> Leather, Black Suede, Amber, Wood</p>
          </div>
        </div>
        
        <div class="py-6 border-b border-outline-variant">
          <button @click="open = open === 2 ? 0 : 2" class="w-full flex items-center justify-between text-left">
            <span class="font-body text-label-lg text-primary uppercase tracking-widest">How to use</span>
            <span class="material-symbols-outlined transition-transform duration-300" :class="open === 2 ? 'rotate-180' : ''">expand_more</span>
          </button>
          <div x-show="open === 2" x-collapse class="mt-6 font-body text-body-md text-on-surface-variant leading-relaxed">
            Apply to pulse points: neck, chest, and wrists for the most enduring fragrance trail.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Luxe Main Product",
  "settings": [],
  "presets": [
    {
      "name": "Luxe Main Product"
    }
  ]
}
{% endschema %}
