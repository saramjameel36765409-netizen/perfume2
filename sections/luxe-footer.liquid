<footer class="bg-primary text-secondary-fixed pt-24 pb-12 px-margin-mobile md:px-margin-desktop border-t border-surface-container-highest/10">
  <div class="max-w-container-max mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-16 mb-24">
      <!-- Brand Story -->
      <div class="md:col-span-1">
        <a href="/" class="flex flex-col items-start group mb-8">
          <span class="font-display text-3xl text-secondary-fixed italic leading-none">{{ section.settings.logo_text | default: 'LUXE AURA' }}</span>
          <span class="font-body text-[10px] text-secondary-fixed uppercase tracking-[0.3em] mt-1">{{ section.settings.tagline | default: 'PARIS' }}</span>
        </a>
        <p class="font-body text-body-md text-surface-container-low/60 leading-relaxed max-w-xs">
          {{ section.settings.description | default: 'Crafting exceptional fragrances since 1924. Our mission is to provide an aura of prestige for the modern connoisseur.' }}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-body text-label-lg text-secondary-fixed uppercase tracking-[0.2em] mb-8">SHOP</h4>
        <nav class="flex flex-col gap-4">
          {%- for link in section.settings.shop_menu.links -%}
            <a href="{{ link.url }}" class="font-body text-body-md text-surface-container-low/60 hover:text-secondary-fixed transition-colors">{{ link.title }}</a>
          {%- endfor -%}
          {%- if section.settings.shop_menu == blank -%}
            <a href="/collections/all" class="font-body text-body-md text-surface-container-low/60 hover:text-secondary-fixed transition-colors">All Fragrances</a>
            <a href="/collections/signature" class="font-body text-body-md text-surface-container-low/60 hover:text-secondary-fixed transition-colors">Signature Series</a>
            <a href="/collections/limited" class="font-body text-body-md text-surface-container-low/60 hover:text-secondary-fixed transition-colors">Limited Editions</a>
          {%- endif -%}
        </nav>
      </div>

      <!-- Information -->
      <div>
        <h4 class="font-body text-label-lg text-secondary-fixed uppercase tracking-[0.2em] mb-8">DISCOVER</h4>
        <nav class="flex flex-col gap-4">
          {%- for link in section.settings.info_menu.links -%}
            <a href="{{ link.url }}" class="font-body text-body-md text-surface-container-low/60 hover:text-secondary-fixed transition-colors">{{ link.title }}</a>
          {%- endfor -%}
          {%- if section.settings.info_menu == blank -%}
            <a href="/pages/our-story" class="font-body text-body-md text-surface-container-low/60 hover:text-secondary-fixed transition-colors">Our Story</a>
            <a href="/pages/contact" class="font-body text-body-md text-surface-container-low/60 hover:text-secondary-fixed transition-colors">Contact Us</a>
            <a href="/pages/shipping" class="font-body text-body-md text-surface-container-low/60 hover:text-secondary-fixed transition-colors">Shipping & Returns</a>
          {%- endif -%}
        </nav>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="font-body text-label-lg text-secondary-fixed uppercase tracking-[0.2em] mb-8">NEWSLETTER</h4>
        <p class="font-body text-body-md text-surface-container-low/60 mb-6">Join our elite circle for early access and exclusive drops.</p>
        {%- form 'customer', class: 'relative' -%}
          <input type="email" name="contact[email]" placeholder="Email address" class="w-full bg-transparent border-b border-surface-container-highest/30 py-3 font-body text-body-md text-secondary-fixed focus:outline-none focus:border-[#D4AF37] transition-colors pr-12 placeholder:text-surface-container-low/30">
          <button type="submit" class="absolute right-0 top-1/2 -translate-y-1/2 text-secondary-fixed hover:text-[#D4AF37] transition-colors">
            <span class="material-symbols-outlined">arrow_forward</span>
          </button>
        {%- endform -%}
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-12 border-t border-surface-container-highest/10 flex flex-col md:flex-row items-center justify-between gap-8">
      <p class="font-body text-body-sm text-surface-container-low/40 uppercase tracking-widest">&copy; {{ 'now' | date: '%Y' }} Luxe Aura. All rights reserved.</p>
      
      <div class="flex items-center gap-8">
        <div class="flex items-center gap-6 text-surface-container-low/40">
          <!-- Social Icons (Placeholders) -->
          <a href="#" class="hover:text-secondary-fixed transition-colors">IG</a>
          <a href="#" class="hover:text-secondary-fixed transition-colors">FB</a>
          <a href="#" class="hover:text-secondary-fixed transition-colors">TW</a>
        </div>
        <div class="flex items-center gap-4">
           <!-- Payment Icons (Standard Shopify loop would go here) -->
           <div class="w-8 h-5 bg-surface-container-low/10 rounded-sm"></div>
           <div class="w-8 h-5 bg-surface-container-low/10 rounded-sm"></div>
           <div class="w-8 h-5 bg-surface-container-low/10 rounded-sm"></div>
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Luxe Footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "LUXE AURA"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "PARIS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop Menu"
    },
    {
      "type": "link_list",
      "id": "info_menu",
      "label": "Info Menu"
    }
  ],
  "presets": [
    {
      "name": "Luxe Footer"
    }
  ]
}
{% endschema %}
