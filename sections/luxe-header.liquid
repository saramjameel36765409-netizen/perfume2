<header class="sticky top-0 z-50 bg-primary/90 backdrop-blur-md border-b border-surface-container-highest/20 px-margin-mobile md:px-margin-desktop py-4">
  <div class="max-w-container-max mx-auto flex items-center justify-between">
    <!-- Mobile Menu Toggle -->
    <button class="md:hidden text-secondary-fixed">
      <span class="material-symbols-outlined">menu</span>
    </button>

    <!-- Logo -->
    <a href="/" class="flex flex-col items-center group">
      <span class="font-display-lg text-[24px] md:text-[32px] text-secondary-fixed italic leading-none group-hover:scale-105 transition-transform">{{ section.settings.logo_text | default: 'LUXE AURA' }}</span>
      <span class="font-body-sm text-[10px] md:text-[12px] text-secondary-fixed uppercase tracking-[0.3em] mt-1">{{ section.settings.tagline | default: 'PARIS' }}</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="font-label-md text-label-md text-surface-container-low hover:text-secondary-fixed transition-colors uppercase tracking-widest">{{ link.label }}</a>
      {%- endfor -%}
      {%- if section.settings.menu == blank -%}
        <a href="#" class="font-label-md text-label-md text-surface-container-low hover:text-secondary-fixed transition-colors uppercase tracking-widest">SHOP</a>
        <a href="#" class="font-label-md text-label-md text-surface-container-low hover:text-secondary-fixed transition-colors uppercase tracking-widest">COLLECTIONS</a>
        <a href="#" class="font-label-md text-label-md text-surface-container-low hover:text-secondary-fixed transition-colors uppercase tracking-widest">OUR STORY</a>
      {%- endif -%}
    </nav>

    <!-- Icons -->
    <div class="flex items-center gap-4 md:gap-6 text-secondary-fixed">
      <button class="hover:scale-110 transition-transform">
        <span class="material-symbols-outlined">search</span>
      </button>
      <a href="/account" class="hidden md:block hover:scale-110 transition-transform">
        <span class="material-symbols-outlined">person</span>
      </a>
      <a href="/cart" class="relative hover:scale-110 transition-transform">
        <span class="material-symbols-outlined">shopping_bag</span>
        {%- if cart.item_count > 0 -%}
          <span class="absolute -top-1 -right-1 bg-[#D4AF37] text-primary text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center">
            {{ cart.item_count }}
          </span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Luxe Header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "LUXE AURA"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "PARIS"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    }
  ],
  "presets": [
    {
      "name": "Luxe Header"
    }
  ]
}
{% endschema %}
