<section class="py-20 md:py-32 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto bg-white">
  <div class="text-center mb-16 md:mb-24">
    <span class="text-[#D4AF37] font-body text-label-md uppercase tracking-[0.4em] mb-4 block">The Collection</span>
    <h2 class="font-display text-display-lg-mobile md:text-display-lg text-primary italic leading-tight">{{ section.settings.title }}</h2>
    <div class="w-12 h-[1px] bg-[#D4AF37] mx-auto mt-8"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-gutter">
    {%- for block in section.blocks -%}
      {%- assign product = block.settings.product -%}
      <div class="group relative flex flex-col items-center">
        <!-- Image Wrapper -->
        <div class="w-full aspect-[3/4] bg-surface-container-low rounded-sm overflow-hidden relative transition-all duration-700 group-hover:bg-[#f3f0e8]">
          <a href="{{ product.url | default: '#' }}" class="block w-full h-full p-8">
            {%- if product != blank -%}
              {{ product.featured_image | image_url: width: 800 | image_tag: class: 'object-contain w-full h-full group-hover:scale-105 transition-transform duration-1000' }}
            {%- else -%}
              <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAQubJzN4mKx1H3Gq1Lrs1QEXLQF7z1U2w-TWOHWZQlq9Q8SwYyuYycqLoBcsbyedONYiWJpZ8NUxp1ePEJvk3cG9Gk9lcFoY6lveEVhxhFn4cFf_WRJ5ad2mCM9Maa0-wnK-Bgbgszu9zQw7bfdwtiHJW256z0JRgyoRgMB2UR_FFNhIPpjegT0hdE6n5zGtNP_JxA1xvTh1YiWQi4KijgbvLQMZTlDJAl5Pu_AYUB0APliojgMLwsSzDoXI36VseKinxqZ_dTGw" class="object-contain w-full h-full group-hover:scale-105 transition-transform duration-1000" alt="Placeholder">
            {%- endif -%}
          </a>
          
          <!-- Quick Add Button Overlay -->
          <div class="absolute bottom-6 left-6 right-6 translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
            {%- if product != blank -%}
              <form method="post" action="/cart/add">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
                <button type="submit" class="w-full py-4 bg-primary text-secondary-fixed font-body text-label-md uppercase tracking-widest rounded-sm shadow-xl">
                  Quick Add
                </button>
              </form>
            {%- else -%}
              <button class="w-full py-4 bg-primary text-secondary-fixed font-body text-label-md uppercase tracking-widest rounded-sm shadow-xl">
                Quick Add
              </button>
            {%- endif -%}
          </div>
        </div>

        <!-- Details -->
        <div class="mt-8 text-center px-4 w-full">
          {%- if block.settings.tag != blank -%}
            <span class="text-[#D4AF37] font-body text-[10px] uppercase tracking-[0.3em] mb-2 block">{{ block.settings.tag }}</span>
          {%- endif -%}
          <h3 class="font-display text-headline-md text-primary italic mb-2 group-hover:text-[#D4AF37] transition-colors">
            <a href="{{ product.url | default: '#' }}">
                {%- if product != blank -%}{{ product.title }}{%- else -%}Midnight Amber{%- endif -%}
            </a>
          </h3>
          <p class="font-body text-body-md text-on-surface-variant opacity-80">
            {%- if product != blank -%}{{ product.price | money }}{%- else -%}$245.00{%- endif -%}
          </p>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Luxe Signature Series",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Signature Series"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 3,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag (e.g. EXCLUSIVE)",
          "default": "EXCLUSIVE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxe Signature Series",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
