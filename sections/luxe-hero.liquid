{%- style -%}
  .luxe-hero-{{ section.id }} {
    min-height: {{ section.settings.min_height_mobile }}px;
  }
  @media screen and (min-width: 768px) {
    .luxe-hero-{{ section.id }} {
      min-height: {{ section.settings.min_height_desktop }}px;
    }
  }
{%- endstyle -%}

<section class="luxe-hero-{{ section.id }} relative flex items-center justify-center overflow-hidden bg-primary">
  <!-- Hero Background Image -->
  <div class="absolute inset-0 z-0">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 3000 | image_tag: class: 'w-full h-full object-cover opacity-60', loading: 'eager' }}
    {%- else -%}
      <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDv77uohTksYcKi4ocjBGvd5Ef7cp3tYeWNMMbdFZ7ZSgsX8hiXx_gT2Rl0wEleKeIr1OJGyiAerm31XMm3O9nWBKTD-N85_PZzvL5F0JnJMNMxdd-31-caOBCIY3ZsWO_CfZLdNpsjuZ523TqBjcd0PNzZb20m35bW2NZ3CXgrNDFYPe5S8k4gmqFV6TlwjOzLH3QQxZe0onUvuM4wmRYBGfgJNaqOaF1rY8k8zzjBlHFIn8xk50VNL8TIhICyoT1jUVlzbNrJgQ" class="w-full h-full object-cover opacity-60" alt="Luxe Aura Hero">
    {%- endif -%}
  </div>

  <!-- Glow Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary/20 via-primary/40 to-primary z-10"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-secondary-fixed/10 via-transparent to-transparent z-11"></div>

  <div class="relative z-20 text-center px-margin-mobile md:px-margin-desktop flex flex-col items-center">
    <h1 class="font-display text-display-lg-mobile md:text-display-lg text-secondary-fixed italic mb-6 leading-tight">
      {{ section.settings.heading }}
    </h1>
    <p class="font-body text-body-md md:text-body-lg text-surface-container-low max-w-2xl mb-10 mx-auto opacity-90">
      {{ section.settings.subtext }}
    </p>
    <a href="{{ section.settings.button_link }}" class="bg-[#D4AF37] text-primary font-body text-label-lg uppercase px-10 py-5 rounded-sm hover:bg-[#ffe088] transition-all duration-500 hover:scale-105 tracking-[0.2em]">
      {{ section.settings.button_label }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Luxe Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SIGNATURE GOLD"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Experience the essence of prestige. A fragrance crafted for the discerning few."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "DISCOVER MORE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "min": 400,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Min Height (Desktop)",
      "default": 820
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 300,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Min Height (Mobile)",
      "default": 600
    }
  ],
  "presets": [
    {
      "name": "Luxe Hero"
    }
  ]
}
{% endschema %}
